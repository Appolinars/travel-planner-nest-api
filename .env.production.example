# ============================================================================
# PRODUCTION .env  — lives on the EC2 instance at ~/app/.env (NEVER commit it).
# Copy this file there:  cp .env.production.example .env  then fill real values.
# Used by BOTH containers (main-api + mailing-service) and by docker-compose.prod.yml.
# `chmod 600 .env` after creating it.
# ============================================================================

# --- Container registry owner (your GitHub username/org, lowercase) ---
# Images are pulled as ghcr.io/${GHCR_OWNER}/<repo>:latest
GHCR_OWNER=your-github-username

NODE_ENV=production
PORT=5000

# --- Postgres (hostname = the compose service name) ---
PG_DB_HOST=postgres
PG_DB_PORT=5432
PG_DB_DATABASE=travel-planner
PG_DB_USERNAME=postgres
PG_DB_PASSWORD=CHANGE_ME_strong_password

# --- Redis (service name; in-container port is 6379, NOT your local 6380) ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- RabbitMQ (service name). guest/guest will NOT work over the docker
#     network, so a real user is required and is auto-created in the broker. ---
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=appuser
RABBITMQ_PASSWORD=CHANGE_ME_strong_password

# --- JWT ---
JWT_ACCESS_SECRET=CHANGE_ME_long_random_string
JWT_REFRESH_SECRET=CHANGE_ME_another_long_random_string

# --- Google OAuth (use the Elastic IP; must match Google console redirect) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://YOUR_ELASTIC_IP:5000/api/auth/google/callback

# --- Email / SMTP (read by the mailing-service) ---
EMAIL_HOST=sandbox.smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_USERNAME=
EMAIL_PASSWORD=

# --- OpenAI ---
OPENAI_API_KEY=

# --- Twitter ---
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
TWITTER_BEARER_TOKEN=
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_CALLBACK_URI=http://YOUR_ELASTIC_IP:5000/twitter/callback

# --- Browserless (PDF generation) ---
BROWSERLESS_API_KEY=
